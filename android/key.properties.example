# Android Release Signing Configuration
# Uso: cp android/key.properties.example android/key.properties
#
# IMPORTANTE: key.properties está en .gitignore — nunca lo commits.
# Genera el keystore con:
#   keytool -genkey -v -keystore android/app/flowroll-release.jks \
#     -alias flowroll -keyalg RSA -keysize 2048 -validity 10000

storePassword=YOUR_STORE_PASSWORD
keyPassword=YOUR_KEY_PASSWORD
keyAlias=flowroll
storeFile=flowroll-release.jks
