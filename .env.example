# FlowRoll — Environment Configuration
#
# Uso: cp .env.example .env
# Luego ejecutar con: flutter run --dart-define-from-file=.env
#
# IMPORTANTE: El archivo .env está en .gitignore — nunca lo commits.
# Las variables se inyectan en compile-time (no son accesibles en runtime como env vars).
#
# Documentación: https://docs.flutter.dev/deployment/dart-define

# ──────────────────────────────────────────────
# API
# ──────────────────────────────────────────────

# URL base del backend Django REST.
# Desarrollo local:  http://localhost:8000
# Staging:           https://api.staging.yourdomain.com
# Producción:        https://api.yourdomain.com
API_BASE_URL=http://localhost:8000
